# ─────────────────────────────────────────────────────────────
# GeoPageScan Backend — Environment Variables
# Copy this file to .env and fill in your values.  NEVER commit .env
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API key — required for AI-powered audits.
# Get one at https://console.anthropic.com
# If left blank, the engine runs in HEURISTIC mode (no API needed) and
# still produces a full scored report from the real scraped signals.
ANTHROPIC_API_KEY=

# Claude model to use for audits.
ANTHROPIC_MODEL=claude-opus-4-5

# Port the Express server listens on (Railway injects its own PORT).
PORT=3001

# Shared secret for the internal server-to-server audit API
# (POST /api/internal/visibility-scan, sent in the X-Internal-Key header).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be set to the SAME value in this app's env and in the calling app (Pulsec).
# Leave blank to disable the internal API (route then always returns 401).
INTERNAL_API_KEY=

# ── Agent-only (optional) ─────────────────────────────────────
# Used by the Optimizer Agent (deploy.js / test-agent.js). Safe to leave blank.
GITHUB_TOKEN=
RAILWAY_DEPLOY_WEBHOOK=
RAILWAY_API_TOKEN=
RAILWAY_SERVICE_ID=
TEST_BACKEND_URL=http://localhost:3001
